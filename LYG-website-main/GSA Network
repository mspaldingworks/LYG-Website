<h3 class="wp-block-heading alignwide has-base-2-color has-text-color has-link-color"><strong>Inclusive language guide for students and teachers</strong></h3>
<!-- /wp:heading -->

<!-- wp:paragraph {"placeholder":"Type / to add a hidden block","style":{"elements":{"link":{"color":{"text":"var:preset|color|contrast-1"}}}},"textColor":"contrast-1"} -->
