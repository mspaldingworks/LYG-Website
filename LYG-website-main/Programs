<style>
/* =========================================================
   LYG PROGRAMS PAGE — everything scoped under #lyg-programs-root
   so it cannot affect any other page. To re-skin, edit the
   custom properties in the next block.
   ========================================================= */
#lyg-programs-root{
  --lyg-teal:#41bdea;          /* brand accent */
  --lyg-teal-dark:#2a93bb;
  --lyg-navy:#10243a;          /* deep surface */
  --lyg-navy-2:#173453;
  --lyg-navy-3:#1f4368;
  --lyg-cream:#f4f9fc;
  --lyg-text:#10243a;
  --lyg-text-invert:#f4f9fc;
  /* category colors reused from the existing Remind buttons */
  --lyg-blue:#41bdea;
  --lyg-green:#86bc62;
  --lyg-purple:#a970dc;
  --lyg-coral:#ec7262;
  --lyg-gold:#f5b53f;
  --lyg-radius:14px;
  --lyg-radius-lg:22px;
  --lyg-shadow:0 6px 24px rgba(16,36,58,.18);
  --lyg-font-display:"Archivo","Archivo Narrow","Bebas Neue",system-ui,sans-serif;
  --lyg-font-body:"Poppins","Inter","Helvetica Neue",system-ui,sans-serif;

  background:var(--lyg-navy);
  color:var(--lyg-text-invert);
  font-family:var(--lyg-font-body);
  font-weight:500;
  line-height:1.5;
  isolation:isolate;
  position:relative;
  z-index:1;
  display:block;
  width:100%;
}
#lyg-programs-root *,#lyg-programs-root *::before,#lyg-programs-root *::after{box-sizing:border-box}
#lyg-programs-root :focus-visible{outline:3px solid var(--lyg-gold);outline-offset:3px;border-radius:6px}
#lyg-programs-root a{color:var(--lyg-teal);text-decoration:underline;text-underline-offset:3px}
#lyg-programs-root a:hover{color:var(--lyg-gold)}
#lyg-programs-root img{max-width:100%;display:block}
#lyg-programs-root h1,#lyg-programs-root h2,#lyg-programs-root h3{
  font-family:var(--lyg-font-display);
  font-weight:800;
  letter-spacing:-.01em;
  line-height:1.05;
  margin:0 0 .6rem;
}
#lyg-programs-root h1{font-size:clamp(2.6rem,7vw,5rem);text-transform:uppercase}
#lyg-programs-root h2{font-size:clamp(1.8rem,4.2vw,3rem)}
#lyg-programs-root h3{font-size:clamp(1.15rem,2.2vw,1.55rem)}
#lyg-programs-root p{margin:0 0 1rem}

.lyg-wrap{width:min(1180px,92vw);margin-inline:auto}
.lyg-section{padding:clamp(2.5rem,6vw,4.5rem) 0}
.lyg-section--light{background:var(--lyg-cream);color:var(--lyg-text)}
.lyg-section--light a{color:var(--lyg-teal-dark)}
.lyg-section--light a:hover{color:var(--lyg-navy)}
.lyg-eyebrow{
  display:inline-block;font-family:var(--lyg-font-display);font-weight:800;
  text-transform:uppercase;letter-spacing:.12em;font-size:.9rem;
  background:var(--lyg-teal);color:var(--lyg-navy);
  padding:.35rem .75rem;border-radius:999px;margin-bottom:1rem;
}
.lyg-h2-wrap{margin-bottom:2rem;text-align:center}
.lyg-h2-wrap p{max-width:52ch;margin:0 auto;opacity:.9}

/* Buttons */
.lyg-btn{
  display:inline-flex;align-items:center;justify-content:center;gap:.5rem;
  font-family:var(--lyg-font-display);font-weight:800;text-transform:uppercase;
  letter-spacing:.03em;font-size:1.02rem;
  padding:.9rem 1.4rem;border-radius:999px;border:3px solid transparent;
  text-decoration:none;cursor:pointer;transition:transform 120ms ease,background 120ms ease;
}
.lyg-btn:hover{transform:translateY(-2px)}
.lyg-btn--primary{background:var(--lyg-teal);color:var(--lyg-navy)}
.lyg-btn--primary:hover{background:#5fccf2;color:var(--lyg-navy)}
.lyg-btn--ghost{background:transparent;color:var(--lyg-cream);border-color:var(--lyg-cream)}
.lyg-btn--ghost:hover{background:var(--lyg-cream);color:var(--lyg-navy)}
.lyg-btn--gold{background:var(--lyg-gold);color:var(--lyg-navy)}
.lyg-btn--gold:hover{background:#ffc658;color:var(--lyg-navy)}

/* HERO CAROUSEL */
.lyg-hero{position:relative;overflow:hidden;background:var(--lyg-navy)}
.lyg-hero__slides{position:absolute;inset:0}
.lyg-hero__slide{
  position:absolute;inset:0;background-size:cover;background-position:center;
  opacity:0;transition:opacity 900ms ease;
}
.lyg-hero__slide.is-active{opacity:1}
.lyg-hero__overlay{
  position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(16,36,58,.45) 0%,rgba(16,36,58,.82) 100%);
}
.lyg-hero__inner{
  position:relative;z-index:2;
  padding:clamp(3.5rem,9vw,7rem) 0 clamp(4rem,10vw,8rem);
}
.lyg-hero::after{
  content:"";position:absolute;inset:auto 0 0 0;height:8px;z-index:3;
  background:linear-gradient(90deg,var(--lyg-coral) 0 20%,var(--lyg-gold) 20% 40%,var(--lyg-green) 40% 60%,var(--lyg-teal) 60% 80%,var(--lyg-purple) 80% 100%);
}
.lyg-hero__tick{display:block;width:64px;height:6px;background:var(--lyg-gold);margin-bottom:1rem;border-radius:2px}
.lyg-hero__lede{font-size:clamp(1.05rem,1.8vw,1.35rem);max-width:44ch;margin-bottom:1.75rem}
.lyg-hero__cta{display:flex;gap:.75rem;flex-wrap:wrap}
.lyg-hero__nav{
  position:absolute;z-index:3;bottom:1.4rem;right:max(4vw,1rem);
  display:flex;align-items:center;gap:.6rem;
}
.lyg-hero__dot{
  width:12px;height:12px;border-radius:50%;border:2px solid var(--lyg-cream);
  background:transparent;cursor:pointer;padding:0;
}
.lyg-hero__dot.is-active{background:var(--lyg-gold);border-color:var(--lyg-gold)}
.lyg-hero__arrow{
  width:40px;height:40px;border-radius:50%;border:0;cursor:pointer;
  background:rgba(244,249,252,.18);color:var(--lyg-cream);font-size:1.2rem;line-height:1;
  display:grid;place-items:center;
}
.lyg-hero__arrow:hover{background:var(--lyg-teal);color:var(--lyg-navy)}

/* QUICK ACTIONS */
.lyg-quick{background:var(--lyg-navy-2);padding:1.25rem 0;border-bottom:6px solid var(--lyg-gold)}
.lyg-quick__grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.75rem}
.lyg-quick__card{
  display:flex;align-items:center;gap:.75rem;
  background:var(--lyg-navy-3);color:var(--lyg-cream);
  padding:1rem 1.1rem;border-radius:var(--lyg-radius);
  text-decoration:none;border:2px solid transparent;
  transition:transform 120ms ease,border-color 120ms ease;
}
.lyg-quick__card:hover{transform:translateY(-2px);border-color:var(--lyg-gold);color:var(--lyg-cream)}
.lyg-quick__icon{
  flex:0 0 44px;width:44px;height:44px;border-radius:12px;
  display:grid;place-items:center;font-size:1.4rem;
  background:var(--lyg-teal);color:var(--lyg-navy);
}
.lyg-quick__card:nth-child(2) .lyg-quick__icon{background:var(--lyg-green);color:var(--lyg-navy)}
.lyg-quick__card:nth-child(3) .lyg-quick__icon{background:var(--lyg-coral);color:var(--lyg-navy)}
.lyg-quick__card:nth-child(4) .lyg-quick__icon{background:var(--lyg-purple);color:var(--lyg-navy)}
.lyg-quick__title{font-family:var(--lyg-font-display);font-weight:800;text-transform:uppercase;font-size:1.05rem;line-height:1}
.lyg-quick__sub{font-size:.83rem;opacity:.85;margin-top:.2rem;display:block}

/* INTRO STRIP */
.lyg-intro{background:var(--lyg-teal);color:var(--lyg-navy);padding:1.6rem 0}
.lyg-intro p{margin:0;font-size:clamp(1.05rem,2vw,1.35rem);font-weight:600;text-align:center}
.lyg-intro strong{font-weight:800}

/* CALENDAR */
.lyg-cal__frame{
  background:#fff;border-radius:var(--lyg-radius-lg);overflow:hidden;
  box-shadow:var(--lyg-shadow);border:4px solid var(--lyg-teal);
}
.lyg-cal__embed{position:relative;width:100%;aspect-ratio:11/6;background:#f3f3f3}
.lyg-cal__embed iframe{position:absolute;inset:0;width:100%;height:100%;border:0}
.lyg-cal__foot{
  display:flex;flex-wrap:wrap;gap:1rem;justify-content:space-between;align-items:center;
  margin-top:1.25rem;font-size:.98rem;
}

/* AGE-GROUP CARDS */
.lyg-groups__grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1.25rem}
.lyg-group{
  display:flex;flex-direction:column;
  background:#fff;color:var(--lyg-text);
  border-radius:var(--lyg-radius-lg);overflow:hidden;
  border-bottom:6px solid var(--lyg-teal);
  text-decoration:none;box-shadow:0 2px 10px rgba(16,36,58,.08);
  transition:transform 150ms ease,box-shadow 150ms ease;
}
.lyg-group:hover{transform:translateY(-4px);box-shadow:var(--lyg-shadow);color:var(--lyg-text)}
.lyg-group__top{
  display:flex;align-items:flex-end;
  aspect-ratio:5/2;width:100%;padding:.9rem 1rem;
  background:var(--lyg-teal);
}
.lyg-group__body{padding:1.1rem 1.25rem 1.4rem}
.lyg-group__age{
  display:inline-block;font-family:var(--lyg-font-display);font-weight:800;
  text-transform:uppercase;font-size:.8rem;letter-spacing:.06em;
  background:var(--lyg-navy);color:var(--lyg-cream);
  padding:.25rem .6rem;border-radius:999px;
}
.lyg-group__title{margin:.6rem 0 .4rem}
.lyg-group__desc{font-size:.95rem;margin:0;opacity:.9}
.lyg-group--junior  .lyg-group__top{background:var(--lyg-gold)}
.lyg-group--junior  {border-bottom-color:var(--lyg-gold)}
.lyg-group--tween   .lyg-group__top{background:var(--lyg-green)}
.lyg-group--tween   {border-bottom-color:var(--lyg-green)}
.lyg-group--teen    .lyg-group__top{background:var(--lyg-teal)}
.lyg-group--teen    {border-bottom-color:var(--lyg-teal)}
.lyg-group--rising  .lyg-group__top{background:var(--lyg-purple)}
.lyg-group--rising  {border-bottom-color:var(--lyg-purple)}
.lyg-group--melanin .lyg-group__top{background:var(--lyg-coral)}
.lyg-group--melanin {border-bottom-color:var(--lyg-coral)}
.lyg-group--tnbi    .lyg-group__top{background:var(--lyg-navy-3)}
.lyg-group--tnbi    {border-bottom-color:var(--lyg-navy-3)}
.lyg-group--ylc     .lyg-group__top{background:var(--lyg-navy)}
.lyg-group--ylc     {border-bottom-color:var(--lyg-navy)}

/* TEXT-UPDATE SIGNUP */
.lyg-texts__grid{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:.75rem;margin-top:1.5rem}
.lyg-texts__btn{
  display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;
  min-height:120px;padding:1rem;border-radius:var(--lyg-radius);
  font-family:var(--lyg-font-display);font-weight:800;text-transform:uppercase;
  text-decoration:none;color:var(--lyg-navy);line-height:1.05;
  border:3px solid transparent;transition:transform 120ms ease,border-color 120ms ease;
}
.lyg-texts__btn:hover{transform:translateY(-3px);border-color:var(--lyg-navy);color:var(--lyg-navy)}
.lyg-texts__btn span{display:block;font-size:.78rem;font-family:var(--lyg-font-body);font-weight:500;text-transform:none;margin-top:.4rem;letter-spacing:0}
.lyg-texts__btn--teen   {background:var(--lyg-blue)}
.lyg-texts__btn--rising {background:var(--lyg-green)}
.lyg-texts__btn--care   {background:var(--lyg-purple);color:#fff}
.lyg-texts__btn--care:hover{color:#fff;border-color:#fff}
.lyg-texts__btn--teach  {background:var(--lyg-coral)}
.lyg-texts__btn--svc    {background:var(--lyg-gold)}

/* CONTACT */
.lyg-contact__grid{display:grid;grid-template-columns:1.1fr .9fr;gap:2rem;align-items:start}
.lyg-contact__form{
  background:var(--lyg-navy-2);color:var(--lyg-cream);
  padding:1.5rem;border-radius:var(--lyg-radius-lg);border:4px solid var(--lyg-teal);
}
.lyg-contact__side ul{list-style:none;padding:0;margin:0;display:grid;gap:.6rem}
.lyg-contact__side li{
  background:var(--lyg-navy-2);padding:.85rem 1rem;border-radius:var(--lyg-radius);
  display:flex;align-items:center;gap:.75rem;
}
.lyg-contact__side .ic{
  width:38px;height:38px;border-radius:9px;background:var(--lyg-teal);color:var(--lyg-navy);
  display:grid;place-items:center;font-size:1.05rem;font-weight:800;flex:0 0 38px;
}
.lyg-contact__note{font-size:.85rem;opacity:.8;margin:.6rem 0 0}

/* PROGRAM & EVENT GUIDE */
.lyg-guide__list{display:grid;gap:.6rem}
.lyg-guide details{
  background:var(--lyg-navy-2);border-radius:var(--lyg-radius);
  border-left:6px solid var(--lyg-teal);overflow:hidden;scroll-margin-top:90px;
}
.lyg-guide details[open]{border-left-color:var(--lyg-gold)}
.lyg-guide summary{
  list-style:none;cursor:pointer;padding:1rem 1.2rem;
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  font-family:var(--lyg-font-display);font-weight:800;text-transform:uppercase;
  font-size:1.05rem;color:var(--lyg-cream);
}
.lyg-guide summary::-webkit-details-marker{display:none}
.lyg-guide summary::after{
  content:"+";font-size:1.6rem;line-height:1;color:var(--lyg-gold);transition:transform 150ms ease;flex:0 0 auto;
}
.lyg-guide details[open] summary::after{content:"\2013"}
.lyg-guide__body{padding:0 1.2rem 1.2rem;color:var(--lyg-cream);opacity:.95}
.lyg-guide__todo{font-style:italic;opacity:.75}

/* RESPONSIVE */
@media (max-width:960px){
  .lyg-quick__grid{grid-template-columns:repeat(2,minmax(0,1fr))}
  .lyg-groups__grid{grid-template-columns:repeat(2,minmax(0,1fr))}
  .lyg-texts__grid{grid-template-columns:repeat(3,minmax(0,1fr))}
  .lyg-contact__grid{grid-template-columns:1fr}
}
@media (max-width:600px){
  .lyg-quick__grid{grid-template-columns:1fr}
  .lyg-groups__grid{grid-template-columns:1fr}
  .lyg-texts__grid{grid-template-columns:repeat(2,minmax(0,1fr))}
  .lyg-cal__embed{aspect-ratio:3/4}
  .lyg-hero__cta{flex-direction:column;align-items:stretch}
  .lyg-hero__cta .lyg-btn{width:100%}
  .lyg-hero__nav{position:static;justify-content:center;margin-top:1.25rem}
}
@media (prefers-reduced-motion:reduce){
  .lyg-hero__slide{transition:none}
}
</style>

