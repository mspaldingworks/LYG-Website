  <script>
    (function () {
      var root = document.getElementById('pw-donate-root');
      if (!root) return;
      var carousel = root.querySelector('[data-pw-carousel]');
      if (!carousel) return;
      var slides = Array.prototype.slice.call(carousel.querySelectorAll('.slide'));
      var prev = carousel.querySelector('[data-prev]');
      var next = carousel.querySelector('[data-next]');
      var count = carousel.querySelector('[data-count]');
      var i = 0;
      function render() {
        slides.forEach(function (s, idx) { s.classList.toggle('active', idx === i); });
        if (count) count.textContent = (i + 1) + ' / ' + slides.length;
      }
      if (prev) prev.addEventListener('click', function () { i = (i - 1 + slides.length) % slides.length; render(); });
      if (next) next.addEventListener('click', function () { i = (i + 1) % slides.length; render(); });
      render();
    })();
  </script>
